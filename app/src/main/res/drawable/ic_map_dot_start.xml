<?xml version="1.0" encoding="utf-8"?>
<!-- Trip-start map marker: red flat dot with a white outline so it stays legible over
     tiles and the breadcrumb polyline in light and dark themes (ANDMAP-010). -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="20dp"
    android:height="20dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <!-- White outer ring (r=11). -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M1,12 a11,11 0 1,0 22,0 a11,11 0 1,0 -22,0 z" />
    <!-- Red fill (r=8.5). -->
    <path
        android:fillColor="#FFD32F2F"
        android:pathData="M3.5,12 a8.5,8.5 0 1,0 17,0 a8.5,8.5 0 1,0 -17,0 z" />
</vector>
